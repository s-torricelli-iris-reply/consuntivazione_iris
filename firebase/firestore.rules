rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function currentUserDocPath() {
      return /databases/$(database)/documents/users/$(request.auth.uid);
    }

    function hasUserProfile() {
      return signedIn() && exists(currentUserDocPath());
    }

    function userRole() {
      return hasUserProfile()
          ? get(currentUserDocPath()).data.role
          : null;
    }

    function isAdmin() {
      return userRole() == 'admin';
    }

    function isManager() {
      return userRole() == 'manager';
    }

    function isTeamLead() {
      return userRole() == 'teamLead';
    }

    function managerOwnsTeamLead(teamLeadId) {
      return teamLeadId is string &&
          teamLeadId.size() > 0 &&
          exists(/databases/$(database)/documents/users/$(teamLeadId)) &&
          get(/databases/$(database)/documents/users/$(teamLeadId)).data.role ==
              'teamLead' &&
          get(/databases/$(database)/documents/users/$(teamLeadId)).data
                  .managerId ==
              request.auth.uid;
    }

    function managerCanUpdateEmployeeAssignment() {
      return isManager() &&
          resource.data.role == 'employee' &&
          request.resource.data.role == resource.data.role &&
          request.resource.data.id == resource.data.id &&
          request.resource.data.email == resource.data.email &&
          request.resource.data.name == resource.data.name &&
          request.resource.data.surname == resource.data.surname &&
          request.resource.data.createdAt == resource.data.createdAt &&
          request.resource.data.isActive == resource.data.isActive &&
          request.resource.data.teamLeadId is string &&
          request.resource.data.managerId == request.auth.uid &&
          managerOwnsTeamLead(request.resource.data.teamLeadId) &&
          request.resource.data
              .diff(resource.data)
              .affectedKeys()
              .hasOnly(['teamLeadId', 'managerId', 'updatedAt']);
    }

    function canManageProjects() {
      return isAdmin() || isManager() || isTeamLead();
    }

    function projectDocPath(projectId) {
      return /databases/$(database)/documents/projects/$(projectId);
    }

    function commessaDocPath(commessaId) {
      return /databases/$(database)/documents/commesse/$(commessaId);
    }

    function projectExists(projectId) {
      return projectId is string &&
          projectId.size() > 0 &&
          exists(projectDocPath(projectId));
    }

    function projectIsBillable(projectId) {
      return projectExists(projectId) &&
          get(projectDocPath(projectId)).data.isBillable == true;
    }

    function commessaExists(commessaId) {
      return commessaId is string &&
          commessaId.size() > 0 &&
          exists(commessaDocPath(commessaId));
    }

    function projectBillingIsValid(data) {
      return !(data.isBillable == true) ||
          commessaExists(data.commessaId);
    }

    function timesheetBillingIsValid(data) {
      return projectExists(data.projectId) &&
          (!(data.commessaId is string) || commessaExists(data.commessaId)) &&
          (!projectIsBillable(data.projectId) ||
              commessaExists(data.commessaId));
    }

    function canManageTimesheets() {
      return isAdmin() || isManager() || isTeamLead();
    }

    function canSelfProvisionUserProfile(userId) {
      return signedIn() &&
          request.auth.uid == userId &&
          request.resource.data.id == request.auth.uid &&
          request.resource.data.role == 'employee';
    }

    match /users/{userId} {
      allow read: if signedIn();
      allow create: if signedIn() &&
          (isAdmin() || canSelfProvisionUserProfile(userId));
      allow update: if signedIn() &&
          (isAdmin() || managerCanUpdateEmployeeAssignment());
      allow delete: if signedIn() && isAdmin();
    }

    match /projects/{projectId} {
      allow read: if signedIn();

      allow create: if signedIn() && (
          projectBillingIsValid(request.resource.data) && (
            isAdmin() ||
            isManager() ||
            (isTeamLead() && request.resource.data.ownerUserId == request.auth.uid)
          )
      );

      allow update: if signedIn() && (
          projectBillingIsValid(request.resource.data) && (
            isAdmin() ||
            isManager() ||
            (isTeamLead() &&
                resource.data.ownerUserId == request.auth.uid &&
                request.resource.data.ownerUserId == request.auth.uid)
          )
      );

      allow delete: if signedIn() && (
          isAdmin() ||
          isManager() ||
          (isTeamLead() && resource.data.ownerUserId == request.auth.uid)
      );
    }

    match /commesse/{commessaId} {
      allow read: if signedIn();
      allow create, update, delete: if signedIn() && canManageProjects();
    }

    match /timesheet_entries/{entryId} {
      allow read: if signedIn();

      // Dev can write only own entries. Admin/Manager/TL can write all entries.
      allow create: if signedIn() && (
          timesheetBillingIsValid(request.resource.data) &&
          (
            request.resource.data.userId == request.auth.uid ||
            canManageTimesheets()
          )
      );

      allow update: if signedIn() && (
          timesheetBillingIsValid(request.resource.data) &&
          (
            ((resource.data.userId == request.auth.uid) &&
                (request.resource.data.userId == request.auth.uid)) ||
            canManageTimesheets()
          )
      );

      allow delete: if signedIn() && (
          resource.data.userId == request.auth.uid ||
          canManageTimesheets()
      );
    }

    match /vacation_requests/{requestId} {
      allow read: if signedIn();

      allow create: if signedIn() &&
          request.resource.data.requesterUserId == request.auth.uid;

      allow update: if signedIn() && (
          resource.data.approverUserId == request.auth.uid ||
          canManageTimesheets()
      );

      allow delete: if signedIn() && canManageTimesheets();
    }
  }
}
